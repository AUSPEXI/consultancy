# Verification harness config — copy to scripts/verify-harness.env (gitignored) and fill in.
# Run:  node --env-file=scripts/verify-harness.env scripts/verify-harness.mjs

# Site to test against (deployed). Defaults to https://l8entspace.com if unset.
HARNESS_BASE_URL=https://l8entspace.com

# Firebase WEB API key (public — same value as NEXT_PUBLIC_FIREBASE_API_KEY).
FIREBASE_API_KEY=

# A real test account on that site (Pro tier, onboarding complete, known config).
TEST_EMAIL=
TEST_PASSWORD=

# The test account's configured brand/domain so route output is checkable by hand.
TEST_BRAND=
TEST_DOMAIN=

# Optional — improves coverage. Comma-separated.
TEST_KEYWORDS=
TEST_COMPETITORS=
TEST_QUERY=

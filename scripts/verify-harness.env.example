# Verification harness config — copy to scripts/verify-harness.env (gitignored) and fill in.
# Run:  node --env-file=scripts/verify-harness.env scripts/verify-harness.mjs

# Site to test against (deployed). Defaults to https://l8entspace.com if unset.
HARNESS_BASE_URL=https://l8entspace.com

# Firebase WEB API key (public — same value as NEXT_PUBLIC_FIREBASE_API_KEY).
FIREBASE_API_KEY=

# ── Auth: provide ONE of the two methods below ──────────────────────────────
#
# Method A — custom token (REQUIRED for Google "Sign in with Google" accounts,
# which have no password). Get the UID from Firebase Console → Authentication →
# Users → the user's "User UID". Service account is the same base64 blob already
# in Netlify env.
TEST_UID=
FIREBASE_SERVICE_ACCOUNT_BASE64=
#
# Method B — email/password (only for accounts created with a password).
TEST_EMAIL=
TEST_PASSWORD=

# The test account's configured brand/domain so route output is checkable by hand.
TEST_BRAND=
TEST_DOMAIN=

# Optional — improves coverage. Comma-separated.
TEST_KEYWORDS=
TEST_COMPETITORS=
TEST_QUERY=

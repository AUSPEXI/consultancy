# Copy this to .env and fill in your keys — never commit .env

# LLM API keys — the probe skips any platform with a missing key
GEMINI_API_KEY=
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
ANTHROPIC_API_KEY=         # Also used by orchestrate.mjs and generate-video-package.mjs

# Email delivery — same Gmail app-password pattern as daily-autopilot
EMAIL_USER=                # your-address@yourdomain.com
EMAIL_APP_PASSWORD=        # 16-char app password: Google → Security → App passwords
REPORT_EMAIL=              # where to send the "ready to film" email (defaults to EMAIL_USER)
